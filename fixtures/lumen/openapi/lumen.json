{
  "openapi": "3.1.0",
  "info": {
    "title": "Lumen API",
    "version": "1.2.0",
    "description": "A design-tool SaaS. The worked example from the design doc."
  },
  "servers": [{ "url": "https://api.lumen.example/v1" }],
