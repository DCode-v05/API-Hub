    "/projects": { "$ref": "./paths/projects.json" }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "Project": { "$ref": "./components/Project.json" },
      "CreateProjectInput": { "$ref": "./components/CreateProjectInput.json" }
    }
  }
}
