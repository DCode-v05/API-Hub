# Copy this file to `.env` (which is gitignored) and fill in your values.
# `cn` loads these at startup; a real environment variable always takes precedence.

# GitHub Personal Access Token for `cn ... --github` (scope: repo contents read).
CN_GITHUB_PAT=ghp_your_token_here

# Optional runtime defaults for generated SDKs / CLI / MCP server:
# CN_BASE_URL=https://api.example/v1
# CN_TOKEN=your_api_token
