# ── Connector Network Studio · environment ──────────────────────────────────
# Copy to apps/studio/.env.local (gitignored) and fill in. Next.js loads it automatically.

# PostgreSQL connection (required). Examples:
#   local docker (see docker-compose.yml):   postgres://postgres:postgres@localhost:5433/connector_network
#   local default install:                   postgres://postgres:postgres@localhost:5432/connector_network
DATABASE_URL=postgres://postgres:postgres@localhost:5433/connector_network

# Optional pool size (default 10).
# DATABASE_POOL_MAX=10

# TLS to the database. Set to "require" for managed/hosted Postgres.
# DATABASE_SSL=require
# Verify the server certificate (default off — many managed DBs use an untrusted chain). Set to 1 to enforce.
# DATABASE_SSL_REJECT_UNAUTHORIZED=1

# Session signing secret. If unset, one is generated and stored in the DB (app_meta).
# Set this in production to a long random string (e.g. `openssl rand -base64 48`) to control rotation.
# STUDIO_SECRET=

# Set to 1 when serving over HTTPS so the session cookie is marked Secure.
# STUDIO_SECURE_COOKIE=1

# Disable the background auto-sync watcher + host reconcile (e.g. in CI builds).
# STUDIO_WATCH_DISABLED=1

# ── SDK publishing (platform-owned org) ─────────────────────────────────────
# All SDKs publish under ONE org/account you configure here. The platform can't create the npm
# org / PyPI account for you — do that once on npmjs.com / pypi.org, then drop the tokens in.
#
# npm: an automation token (npmjs.com → Access Tokens → Granular/Automation) + the scope you own.
# STUDIO_NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STUDIO_NPM_SCOPE=@connector-network
#
# PyPI: an API token (pypi.org → Account → API tokens) + a globally-unique name prefix.
# Requires `build` + `twine` on the host:  pip install build twine
# STUDIO_PYPI_TOKEN=pypi-xxxxxxxxxxxxxxxxxxxx
# STUDIO_PYPI_PREFIX=cn-
